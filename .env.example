# ──── نسخ نموذجي من المتغيرات البيئية لـ Nexora ────
# انسخ هذا الملف إلى .env وعدّل القيم للإنتاج

# ──── Backend ────
NEXORA_BIND=0.0.0.0:8080
RUST_LOG=info
RUST_BACKTRACE=1
DATABASE_URL=postgres://nexora:nexora_secret@postgres:5432/nexora

# يجب تغييره في الإنتاج (32+ بايت عشوائي)
NEXORA_JWT_SECRET=change_me_in_production_please_use_long_random_string

# ──── Frontend ────
BACKEND_URL=http://backend:8080

# ──── Postgres ────
POSTGRES_DB=nexora
POSTGRES_USER=nexora
POSTGRES_PASSWORD=nexora_secret

# ──── Grafana ────
GF_SECURITY_ADMIN_PASSWORD=admin
