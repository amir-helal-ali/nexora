.gitignore

# Docker
Dockerfile.*
docker-compose.yml

# Docs (لا حاجة لها في البناء)
docs/
deploy/
scripts/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Logs
*.log
